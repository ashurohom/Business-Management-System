<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard grouping by Quotation -->
    <record id="view_activity_dashboard_tree" model="ir.ui.view">
        <field name="name">activity.dashboard.tree</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <!-- This acts as the level 1 view as requested, grouping activities practically by showing sale_orders that have activities -->
            <tree string="Quotation Activity Tracking" create="0" edit="0" delete="0">
                <field name="name" string="Quotation"/>
                <field name="partner_id" string="Customer"/>
                <field name="total_activities"/>
                <field name="latest_shipping_status"
                       widget="badge" 
                       decoration-success="latest_shipping_status == 'delivered'" 
                       decoration-info="latest_shipping_status == 'shipped'" 
                       decoration-muted="latest_shipping_status == 'cancelled'" 
                       decoration-warning="latest_shipping_status == 'in_transit'"/>
                <field name="overall_activity_status" string="Overall Status"/>
                <field name="state" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_activity_dashboard_form" model="ir.ui.view">
        <field name="name">activity.dashboard.form</field>
        <field name="model">sale.order</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form string="Quotation Activity Details" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="user_id" string="Salesperson" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_order" string="Created On" readonly="1"/>
                            <field name="overall_activity_status" string="Overall Status" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Activity Timeline" name="activity_timeline">
                            <field name="activity_timeline_ids" widget="list" nolabel="1" readonly="1">
                                <tree string="Activities" create="0" edit="0" delete="0" decoration-info="activity_type == 'quotation'" decoration-success="activity_type in ('sale', 'delivery')" decoration-warning="activity_type == 'invoice'" decoration-primary="activity_type == 'shipping'">
                                    <field name="datetime" string="When Created"/>
                                    <field name="user_id" string="Who Created"/>
                                    <field name="activity_type" widget="badge"/>
                                    <field name="description" string="Document Details / Description"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="tracking_link" widget="url" optional="hide"/>
                                    <field name="shipping_status" optional="show" widget="badge" 
                                           decoration-success="shipping_status == 'delivered'" 
                                           decoration-info="shipping_status == 'shipped'" 
                                           decoration-muted="shipping_status == 'cancelled'" 
                                           decoration-warning="shipping_status == 'in_transit'"/>
                                    <field name="status" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_activity_dashboard" model="ir.actions.act_window">
        <field name="name">Quotation Activity Tracking</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_activity_dashboard_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_activity_dashboard_form')})]"/>
        <field name="domain">[('activity_timeline_ids', '!=', False)]</field>
    </record>

</odoo>
