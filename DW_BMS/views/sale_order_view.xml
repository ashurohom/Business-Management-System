<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_total_weight_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.total.weight.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="total_products_weight" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_stock_qty_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.stock.qty.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="after">
                <field name="stock_qty" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="after">
                <field name="price_incl_tax" string="Rate Incl Tax"/>
                <field name="min_sale_price" string="Minimum Sale Price" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="after">
                <field name="price_incl_tax" string="Rate Incl Tax"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_hsn_position_fix" model="ir.ui.view">
        <field name="name">sale.order.form.hsn.position.fix</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="99"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_template_id' or @name='product_id'][last()]" position="after">
                <field name="hsn_code" position="move"/>
            </xpath>
        </field>
    </record>

    <template id="report_saleorder_document_total_weight" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@id='total']//table" position="inside">
            <tr>
                <td><strong>Total Products Weight(KG)</strong></td>
                <td class="text-end">
                    <span t-field="doc.total_products_weight"/>
                </td>
            </tr>
        </xpath>
    </template>

    <record id="view_order_form_print_quotation_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.print.quotation.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(DW_BMS.action_report_saleorder_custom_quotation)d" string="Print Quotation" type="action" class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_packing_team_hide_sale_buttons" model="ir.ui.view">
        <field name="name">sale.order.form.packing.team.hide.sale.buttons</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="101"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='create_invoice_percentage']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_by_email_primary']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_proforma_primary']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='action_confirm']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="(//button[@name='action_confirm'])[2]" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_proforma']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_by_email']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='payment_action_capture']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='payment_action_void']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_unlock']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_preview_sale_order']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_draft']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_lock']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_packing_team_customer_readonly" model="ir.ui.view">
        <field name="name">sale.order.form.packing.team.customer.readonly</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="102"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='partner_details']/field[@name='partner_id']" position="attributes">
                <attribute name="options" groups="DW_BMS.group_packing_team">{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//group[@name='partner_details']/field[@name='partner_invoice_id']" position="attributes">
                <attribute name="options" groups="DW_BMS.group_packing_team">{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//group[@name='partner_details']/field[@name='partner_shipping_id']" position="attributes">
                <attribute name="options" groups="DW_BMS.group_packing_team">{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_packing_team_readonly" model="ir.ui.view">
        <field name="name">sale.order.form.packing.team.readonly</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes" groups="DW_BMS.group_packing_team">
                <attribute name="create">false</attribute>
                <attribute name="edit">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_quotation_tree_packing_team_readonly" model="ir.ui.view">
        <field name="name">sale.quotation.tree.packing.team.readonly</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes" groups="DW_BMS.group_packing_team">
                <attribute name="create">false</attribute>
                <attribute name="edit">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_order_tree_packing_team_readonly" model="ir.ui.view">
        <field name="name">sale.order.tree.packing.team.readonly</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes" groups="DW_BMS.group_packing_team">
                <attribute name="create">false</attribute>
                <attribute name="edit">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_packing_team_quotations" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="context">{'create': 0, 'edit': 0, 'delete': 0}</field>
        <field name="domain">[('state', 'in', ('draft', 'sent'))]</field>
    </record>

    <record id="action_packing_team_orders" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="context">{'create': 0, 'edit': 0, 'delete': 0}</field>
        <field name="domain">[('state', 'not in', ('draft', 'sent', 'cancel'))]</field>
    </record>

    <record id="action_packing_team_quotations_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="sale.view_quotation_tree"/>
        <field name="act_window_id" ref="action_packing_team_quotations"/>
    </record>

    <record id="action_packing_team_quotations_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="sale.view_order_form"/>
        <field name="act_window_id" ref="action_packing_team_quotations"/>
    </record>

    <record id="action_packing_team_orders_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="sale.view_order_tree"/>
        <field name="act_window_id" ref="action_packing_team_orders"/>
    </record>

    <record id="action_packing_team_orders_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="sale.view_order_form"/>
        <field name="act_window_id" ref="action_packing_team_orders"/>
    </record>

    <menuitem id="menu_packing_team_sales_orders"
              name="Orders"
              parent="sale.sale_menu_root"
              sequence="10"
              groups="DW_BMS.group_packing_team"/>

    <menuitem id="menu_packing_team_sale_quotations"
              name="Quotations"
              parent="menu_packing_team_sales_orders"
              action="action_packing_team_quotations"
              sequence="10"
              groups="DW_BMS.group_packing_team"/>

    <menuitem id="menu_packing_team_sale_orders"
              name="Orders"
              parent="menu_packing_team_sales_orders"
              action="action_packing_team_orders"
              sequence="20"
              groups="DW_BMS.group_packing_team"/>
</odoo>
