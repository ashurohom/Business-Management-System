<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_custom_ship_bill_address" model="ir.ui.view">
        <field name="name">sale.order.form.custom.ship.bill.address</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="total_products_weight" readonly="1"/>
            </xpath>
            <xpath expr="//group[@name='sale_header']" position="after">
                <group col="1" colspan="2">
                    <group>
                        <field name="delivery_type"/>
                    </group>
                    <group col="2">
                        <group col="1" string="Billing Address">
                            <group col="2">
                                <label for="bill_to_same_as_customer" string="Same As Customer Address"/>
                                <field name="bill_to_same_as_customer" nolabel="1"/>
                            </group>
                            <group col="2">
                                <label for="billing_customer_name" string="Name"/>
                                <field name="billing_customer_name"
                                       nolabel="1"
                                       readonly="bill_to_same_as_customer"/>
                                <field name="billing_partner_id" invisible="1"/>
                            </group>
                            <group col="2">
                                <label for="billing_mobile" string="Mobile Number"/>
                                <field name="billing_mobile" nolabel="1" readonly="bill_to_same_as_customer"/>
                            </group>
                            <group col="2">
                                <label for="bill_to_address" string="Address"/>
                                <field name="bill_to_address"
                                       nolabel="1"
                                       widget="text"
                                       placeholder="Flat/Building, Street, Area"
                                       readonly="bill_to_same_as_customer"/>
                            </group>
                            <group col="4">
                                <label for="bill_to_city" string="City"/>
                                <field name="bill_to_city" nolabel="1" placeholder="City" readonly="bill_to_same_as_customer"/>
                                <label for="bill_to_state_id" string="State"/>
                                <field name="bill_to_state_id" nolabel="1" placeholder="State" readonly="bill_to_same_as_customer"/>
                            </group>
                            <group col="4">
                                <label for="bill_to_country" string="Country"/>
                                <field name="bill_to_country" nolabel="1" placeholder="Country" readonly="bill_to_same_as_customer"/>
                                <label for="bill_to_zip" string="Pincode"/>
                                <field name="bill_to_zip" nolabel="1" placeholder="PIN Code" readonly="bill_to_same_as_customer"/>
                            </group>
                        </group>
                        <group col="1" string="Shipping Address">
                            <group col="2">
                                <label for="ship_to_same_as_customer" string="Same As Customer Address"/>
                                <field name="ship_to_same_as_customer" nolabel="1"/>
                            </group>
                            <group col="2">
                                <label for="shipping_customer_name" string="Name"/>
                                <field name="shipping_customer_name"
                                       nolabel="1"
                                       readonly="ship_to_same_as_customer"/>
                                <field name="shipping_partner_id" invisible="1"/>
                            </group>
                            <group col="2">
                                <label for="shipping_mobile" string="Mobile Number"/>
                                <field name="shipping_mobile" nolabel="1" readonly="ship_to_same_as_customer"/>
                            </group>
                            <group col="2">
                                <label for="ship_to_address" string="Address"/>
                                <field name="ship_to_address"
                                       nolabel="1"
                                       widget="text"
                                       placeholder="Flat/Building, Street, Area"
                                       readonly="ship_to_same_as_customer"/>
                            </group>
                            <group col="4">
                                <label for="ship_to_city" string="City"/>
                                <field name="ship_to_city" nolabel="1" placeholder="City" readonly="ship_to_same_as_customer"/>
                                <label for="ship_to_state_id" string="State"/>
                                <field name="ship_to_state_id" nolabel="1" placeholder="State" readonly="ship_to_same_as_customer"/>
                            </group>
                            <group col="4">
                                <label for="ship_to_country" string="Country"/>
                                <field name="ship_to_country" nolabel="1" placeholder="Country" readonly="ship_to_same_as_customer"/>
                                <label for="ship_to_zip" string="Pincode"/>
                                <field name="ship_to_zip" nolabel="1" placeholder="PIN Code" readonly="ship_to_same_as_customer"/>
                            </group>
                        </group>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_stock_qty_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.stock.qty.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="after">
                <field name="stock_qty" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="after">
                <field name="price_incl_tax" string="Rate Incl Tax"/>
                <field name="min_sale_price" string="Minimum Sale Price" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="after">
                <field name="price_incl_tax" string="Rate Incl Tax"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_hsn_position_fix" model="ir.ui.view">
        <field name="name">sale.order.form.hsn.position.fix</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="99"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_template_id' or @name='product_id'][last()]" position="after">
                <field name="hsn_code" position="move"/>
            </xpath>
        </field>
    </record>

    <template id="report_saleorder_document_total_weight" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@id='total']//table" position="inside">
            <tr>
                <td><strong>Total Products Weight(KG)</strong></td>
                <td class="text-end">
                    <span t-field="doc.total_products_weight"/>
                </td>
            </tr>
        </xpath>
    </template>

    <record id="view_order_form_print_quotation_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.print.quotation.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(DW_BMS.action_report_saleorder_custom_quotation)d" string="Print Quotation" type="action" class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_packing_team_hide_sale_buttons" model="ir.ui.view">
        <field name="name">sale.order.form.packing.team.hide.sale.buttons</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="101"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='create_invoice_percentage']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_by_email_primary']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_proforma_primary']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='action_confirm']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="(//button[@name='action_confirm'])[2]" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_proforma']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@id='send_by_email']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='payment_action_capture']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='payment_action_void']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_unlock']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_preview_sale_order']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_draft']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
            <xpath expr="//button[@name='action_lock']" position="attributes">
                <attribute name="groups">!DW_BMS.group_packing_team</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_packing_team_customer_readonly" model="ir.ui.view">
        <field name="name">sale.order.form.packing.team.customer.readonly</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority" eval="102"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='partner_details']/field[@name='partner_id']" position="attributes">
                <attribute name="options" groups="DW_BMS.group_packing_team,!DW_BMS.group_bms_admin,!DW_BMS.group_bms_sales,!DW_BMS.group_sales_team,!base.group_system">{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//group[@name='partner_details']/field[@name='partner_invoice_id']" position="attributes">
                <attribute name="options" groups="DW_BMS.group_packing_team,!DW_BMS.group_bms_admin,!DW_BMS.group_bms_sales,!DW_BMS.group_sales_team,!base.group_system">{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//group[@name='partner_details']/field[@name='partner_shipping_id']" position="attributes">
                <attribute name="options" groups="DW_BMS.group_packing_team,!DW_BMS.group_bms_admin,!DW_BMS.group_bms_sales,!DW_BMS.group_sales_team,!base.group_system">{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>

