<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================= -->
    <!-- DW BMS CATEGORY -->
    <!-- ========================= -->
    <record id="module_category_dw_bms" model="ir.module.category">
        <field name="name">DW BMS</field>
        <field name="description">Business Management System</field>
        <field name="sequence">10</field>
    </record>

    <!-- ========================= -->
    <!-- BMS ADMIN -->
    <!-- ========================= -->
    <record id="group_bms_admin" model="res.groups">
        <field name="name">BMS Admin</field>
        <field name="category_id" ref="module_category_dw_bms"/>
    </record>

    <!-- ========================= -->
    <!-- BMS SALES USER -->
    <!-- ========================= -->
    <record id="group_bms_sales" model="res.groups">
        <field name="name">BMS Sales User</field>
        <field name="category_id" ref="module_category_dw_bms"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <!-- ========================= -->
    <!-- BMS PURCHASE USER -->
    <!-- ========================= -->
    <record id="group_bms_purchase" model="res.groups">
        <field name="name">BMS Purchase User</field>
        <field name="category_id" ref="module_category_dw_bms"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>

    <!-- ========================= -->
    <!-- BMS ACCOUNTS USER -->
    <!-- ========================= -->
    <record id="group_bms_accounts" model="res.groups">
        <field name="name">BMS Accounts User</field>
        <field name="category_id" ref="module_category_dw_bms"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_readonly'))]"/>
    </record>

    <!-- ========================= -->
    <!-- BMS REPORT USER -->
    <!-- ========================= -->
    <record id="group_bms_report" model="res.groups">
        <field name="name">BMS Report User</field>
        <field name="category_id" ref="module_category_dw_bms"/>
    </record>

    <!-- ========================= -->
    <!-- BMS MANUFACTURING USER -->
    <!-- ========================= -->
    <record id="group_bms_manufacturing" model="res.groups">
        <field name="name">BMS Manufacturing User</field>
        <field name="category_id" ref="module_category_dw_bms"/>
        <field name="implied_ids" eval="[(4, ref('mrp.group_mrp_user'))]"/>
    </record>



    <!-- ========================= -->
    <!-- HIDE APPS MENU -->
    <!-- ========================= -->
    <record id="base.menu_apps" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- ========================= -->
    <!-- BMS INVENTORY USER -->
    <!-- ========================= -->
    <record id="group_bms_inventory" model="res.groups">
        <field name="name">BMS Inventory User</field>
        <field name="category_id" ref="module_category_dw_bms"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <!-- ========================= -->
    <!-- HIDE INVENTORY MENU -->
    <!-- ========================= -->
    <record id="stock.menu_stock_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('group_bms_admin'), ref('group_bms_purchase'), ref('group_bms_inventory')])]"/>
        <field name="sequence">7</field>
    </record>

    <!-- ========================= -->
    <!-- HIDE MANUFACTURING MENU -->
    <!-- ========================= -->
    <record id="mrp.menu_mrp_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('group_bms_admin'), ref('group_bms_manufacturing')])]"/>
        <field name="sequence">8</field>
    </record>

    <!-- ========================= -->
    <!-- HIDE SALES MENU -->
    <!-- ========================= -->
    <record id="sale.sale_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('group_bms_admin'), ref('group_bms_sales'), ref('group_bms_accounts')])]"/>
        <field name="sequence">4</field>
    </record>

    <!-- ========================= -->
    <!-- APP MENU ORDER -->
    <!-- 1. Home (set in home module, not here) -->
    <!-- 2. Discuss -->
    <!-- 3. Contacts -->
    <!-- 4. Sales -->
    <!-- 5. Invoicing -->
    <!-- 6. Purchase -->
    <!-- 7. Inventory -->
    <!-- 8. Manufacturing -->
    <!-- 9. Employees -->
    <!-- ========================= -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="sequence">2</field>
    </record>

    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="sequence">3</field>
    </record>

    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="sequence">5</field>
    </record>

    <record id="purchase.menu_purchase_root" model="ir.ui.menu">
        <field name="sequence">6</field>
    </record>

    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="sequence">9</field>
    </record>

</odoo>
