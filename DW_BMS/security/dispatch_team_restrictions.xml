        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[('picking_type_code', '=', 'outgoing')]</field>
        <field name="groups" eval="[(4, ref('DW_BMS.group_dispatch_team'))]"/>
        <field name="perm_read" eval="True"/>
